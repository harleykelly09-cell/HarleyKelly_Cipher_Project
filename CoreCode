class SubstitutionCipher:
    def __init__(self, key: str):
        alphabet = "ABCDEFGHIJKLMNOPQRSTUVWXYZ"

        key = key.upper()
        seen = set()

        key_unique = "".join([c for c in key if c not in seen and not seen.add(c)])
        remaining = "".join([c for c in alphabet if c not in key_unique])

        self.alphabet = key_unique + remaining

        self.enc = str.maketrans(alphabet, self.alphabet)
        self.dec = str.maketrans(self.alphabet, alphabet)

    def encode(self, text: str) -> str:
        return text.upper().translate(self.enc)

    def decode(self, text: str) -> str:
        return text.upper().translate(self.dec)


class PolybiusCipher:
    def __init__(self, key=""):
        # 5x5 alphabet (J merged into I)
        alphabet = "ABCDEFGHIKLMNOPQRSTUVWXYZ"

        key = key.upper().replace("J", "I")
        seen = set()

        key_unique = "".join(
            [c for c in key if c in alphabet and not (c in seen or seen.add(c))]
        )

        remaining = "".join([c for c in alphabet if c not in key_unique])

        self.square = key_unique + remaining

        self.encode_map = {}
        self.decode_map = {}

        for i, char in enumerate(self.square):
            row = i // 5 + 1
            col = i % 5 + 1
            code = f"{row}{col}"

            self.encode_map[char] = code
            self.decode_map[code] = char

    def encode(self, text: str) -> str:
        result = []

        for c in text.upper():
            if c == "J":
                c = "I"

            if c in self.encode_map:
                result.append(self.encode_map[c])
            else:
                result.append(c)

        return "+".join(result)

    def decode(self, text: str) -> str:
        parts = text.split("+")
        result = []

        for p in parts:
            if p in self.decode_map:
                result.append(self.decode_map[p])
            else:
                result.append(p)

        return "".join(result)


class CipherEngine:
    def __init__(self, key: str, mode: str):
        self.key = key
        self.mode = mode

    def process(self, text: str, direction="encode"):
        if self.mode == "Substitution":
            steps = ["Substitution"]
        elif self.mode == "Polybius":
            steps = ["Polybius"]
        else:
            steps = ["Substitution", "Polybius"]

        if direction == "decode":
            steps = steps[::-1]

        for step in steps:
            if step == "Substitution":
                cipher = SubstitutionCipher(self.key)
                text = cipher.encode(text) if direction == "encode" else cipher.decode(text)

            elif step == "Polybius":
                cipher = PolybiusCipher(self.key)
                text = cipher.encode(text) if direction == "encode" else cipher.decode(text)

        return text


# ============================================ #
# //              Tkinter UI               // #
# ============================================ #

class CipherUI:
    def __init__(self, root):
        self.root = root
        self.root.title("Cipher System")
        self.root.geometry("600x500")

        self.file_path = ""

        tk.Label(root, text="Codeword").pack()
        self.key_entry = tk.Entry(root, width=40)
        self.key_entry.pack()

        tk.Label(root, text="Mode").pack()
        self.mode_var = tk.StringVar(value="Substitution")

        tk.OptionMenu(
            root,
            self.mode_var,
            "Substitution",
            "Polybius",
            "Substitution -> Polybius"
        ).pack()

        tk.Button(root, text="Load File", command=self.load_file).pack(pady=5)
        tk.Button(root, text="Encode", command=self.encode).pack(pady=5)
        tk.Button(root, text="Decode", command=self.decode).pack(pady=5)

        self.output_box = tk.Text(root, height=15, width=70)
        self.output_box.pack(pady=10)

    def load_file(self):
        self.file_path = filedialog.askopenfilename()

    def get_text(self):
        if self.file_path:
            with open(self.file_path, "r", encoding="utf-8") as f:
                return f.read()
        return self.output_box.get("1.0", tk.END)

    def show_output(self, text):
        self.output_box.delete("1.0", tk.END)
        self.output_box.insert(tk.END, text)

    def encode(self):
        text = self.get_text()
        engine = CipherEngine(self.key_entry.get(), self.mode_var.get())
        result = engine.process(text, "encode")
        self.show_output(result)

    def decode(self):
        text = self.get_text()
        engine = CipherEngine(self.key_entry.get(), self.mode_var.get())
        result = engine.process(text, "decode")
        self.show_output(result)


